<h1>Edit Project</h1>

<%= tag.div data: { controller: "tabs" } do %>
  <nav>
    <ul>
      <li>
        <%= tag.a "Details", href: "#", data: {
          tabs_target: "tab",
          action: "click->tabs#change:prevent"
        } %>
      </li>
      <li>
        <%= tag.a "Members", href: "#", data: {
          tabs_target: "tab",
          action: "click->tabs#change:prevent"
        } %>
      </li>
    </ul>
  </nav>

  <div>
    <%= tag.div class: "hidden", data: { tabs_target: "panel" } do %>
      <%= render "form", project: @project %>
    <% end %>


    <%= tag.div class: "hidden", data: { tabs_target: "panel" } do %>
      <section>
        <% @project.users.each do |user| %>
          <div class="flex items-center">
            <%= tag.div user.name %>
            <%= button_to "Remove", project_membership_path(@project, user), method: :delete unless Current.user == user %>
          </div>
        <% end %>
      </section>

      <% User.where.not(id: @project.user_ids).each do |user| %>
        <%= button_to "Add #{user.name}", project_memberships_path(@project, user_id: user) %>
      <% end %>
    <% end %>
  </div>
<% end %>